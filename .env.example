# ═══════════════════════════════════════════════════════
#  NIS2 Compliance Platform — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════

FLASK_ENV=development

# ── Security ─────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# ── Database ─────────────────────────────────────────────
# Local PostgreSQL:
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nis2_dev
# Production (Render/Railway/Supabase):
# DATABASE_URL=postgresql://user:pass@host:5432/nis2_prod

# Optional: PostgreSQL schema name (leave empty for public)
# DB_SCHEMA=nis2

# ── AI — Claude API (for ISMS document generation) ───────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email / SMTP ─────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@nis2-compliance.de

# ── Stripe (payments) ────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PROFESSIONAL=price_...

# ── Trial period (days) ───────────────────────────────────
TRIAL_DAYS=14

# ── Site URL (for email links) ────────────────────────────
SITE_BASE_URL=http://localhost:5000

# ── NIS2 Site Audit Microservice (optional) ──────────────
# Docker container with nmap, nuclei, testssl, nikto tools
# NIS2_MICROSERVICE_URL=http://localhost:8081
